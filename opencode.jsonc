{
  "$schema": "https://opencode.ai/config.json",
  // Default shell for bash tool calls (use bash for WSL instead of PowerShell)
  "shell": "/bin/bash",
  // Default model for any agent that doesn't specify one
  "model": "opencode-go/qwen3.6-plus",
  "default_agent": "manager",
  "instructions": ["AGENTS.md", "WORKING_STATE.md"],

  "provider": {
    "opencode-go": {
      "models": {
        "qwen3.6-plus": {
          "options": {
            "preserve_thinking": true
          }
        },
        "qwen3.7-plus": {
          "options": {
            "preserve_thinking": true
          }
        }
      }
    }
  },

  "tool_output": {
    "max_lines": 1000,
    "max_bytes": 40960
  },
  "lsp": true,

  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 10,
    "preserve_recent_tokens": 4000
  },

  "permission": {
    "bash": {
      "*": "allow",
      "rm": "ask",
      "rm *": "ask",
      "* rm": "ask",
      "* rm *": "ask"
    }
  }
}
