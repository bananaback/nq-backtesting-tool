{
  "$schema": "https://opencode.ai/config.json",
  "shell": "/bin/bash",
  "model": "deepseek/deepseek-v4-pro",
  "default_agent": "ds-lead",
  "instructions": [
    "DS_WORKFLOW.md"
  ],
  "provider": {
    "deepseek": {
      "models": {
        "deepseek-v4-pro": {
          "options": {
            "reasoning_effort": "medium"
          }
        },
        "deepseek-v4-flash": {
          "options": {
            "thinking": {
              "type": "disabled"
            },
            "reasoning_effort": "low"
          }
        }
      }
    }
  },
  "tool_output": {
    "max_lines": 1000,
    "max_bytes": 40960
  },
  "lsp": true,
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 8,
    "preserve_recent_tokens": 4000
  },
  "permission": {
    "bash": {
      "*": "allow",
      "rm": "ask",
      "rm *": "ask",
      "* rm": "ask",
      "* rm *": "ask"
    }
  }
}
